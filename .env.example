# OOPS-AI 环境变量配置
# 复制此文件为 .env 并根据需要修改

# 数据库配置
DATABASE_URL="postgresql://oops_user:oops_password@localhost:5432/oops_ai"

# JWT 配置
JWT_SECRET="your-jwt-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# LLM API 密钥
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""
QIANWEN_API_KEY=""

# Ollama 配置
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama2"

# 应用配置
PORT=3000
NODE_ENV="development"
LOG_LEVEL="info"

# 前端配置
VITE_API_URL="http://localhost:3000"

# 向量数据库配置
CHROMADB_HOST="localhost"
CHROMADB_PORT=8000
CHROMADB_COLLECTION="requirements"

# 安全配置
CORS_ORIGIN="http://localhost:5173"
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# 邮件配置（可选）
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""