{
  "name": "oops-ai",
  "version": "1.0.0",
  "description": "软件团队专属需求智能体",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel --filter=@oops-ai/frontend --filter=@oops-ai/backend run dev",
    "dev:frontend": "pnpm --filter=@oops-ai/frontend run dev",
    "dev:backend": "pnpm --filter=@oops-ai/backend run start:dev",
    "build": "pnpm -r run build",
    "build:frontend": "pnpm --filter=@oops-ai/frontend run build",
    "build:backend": "pnpm --filter=@oops-ai/backend run build",
    "build:shared": "pnpm --filter=@oops-ai/shared run build",
    "test": "pnpm -r run test",
    "test:frontend": "pnpm --filter=@oops-ai/frontend run test",
    "test:backend": "pnpm --filter=@oops-ai/backend run test",
    "lint": "pnpm -r run lint",
    "lint:frontend": "pnpm --filter=@oops-ai/frontend run lint",
    "lint:backend": "pnpm --filter=@oops-ai/backend run lint",
    "typecheck": "pnpm -r run typecheck",
    "typecheck:frontend": "pnpm --filter=@oops-ai/frontend run typecheck",
    "typecheck:backend": "pnpm --filter=@oops-ai/backend run typecheck",
    "prisma:generate": "pnpm --filter=@oops-ai/shared run generate",
    "prisma:migrate": "pnpm --filter=@oops-ai/backend run prisma:migrate",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}